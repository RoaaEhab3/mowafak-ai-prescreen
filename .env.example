# Copy to .env and fill in. .env is git-ignored (see .gitignore / SECURITY.md).

# --- Gemini (Google AI Studio) ---
# Required for CV parsing, question generation, response evaluation, reporting.
GEMINI_API_KEY=
# Model id used for all Gemini calls. Defaults to gemini-1.5-flash if unset.
GEMINI_MODEL=gemini-1.5-flash

# --- Supabase (backend storage) ---
# The API reads SUPABASE_SERVICE_KEY (scripts/reset.sh also accepts
# SUPABASE_SERVICE_ROLE_KEY / SUPABASE_KEY). Apply backend/schema.sql first.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# --- Whisper (speech-to-text) ---
# base | small | medium. Needs ffmpeg on PATH (or set FFMPEG_BIN below).
WHISPER_MODEL=base
# Optional: directory containing the ffmpeg binary, if not already on PATH.
# FFMPEG_BIN=

# --- Backend / CORS ---
# Comma-separated origins allowed to call the API (defaults to "*" in dev).
# MOWAFAK_CORS_ORIGINS=http://localhost:8000

# --- HR review UI (app.py) ---
# Where the Chainlit HR UI finds the API, and the reviewer identity it records.
# MOWAFAK_API_BASE=http://localhost:8000
# MOWAFAK_HR_REVIEWER_ID=hr_reviewer
